APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=menu
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Laravel Reverb (WebSockets). REVERB_HOST/PORT/SCHEME describe the PUBLIC
# endpoint the browser connects to (in prod: wss on 443 behind nginx). The
# REVERB_SERVER_* pair is the local bind address for the `reverb:start` daemon.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Web Push (VAPID). Generate with `php artisan webpush:vapid`. The public key is
# exposed to the SPA via GET /api/v1/push/vapid-public-key. VAPID_SUBJECT is a
# mailto:/URL identifying the app — required by Safari/iOS. Never rotate these:
# every stored subscription is bound to the key pair that created it.
VAPID_SUBJECT="mailto:admin@example.com"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

IMAGE_DISK=public
IMAGE_ORIGINALS_DISK=local
IMAGE_FORMAT=webp
IMAGE_QUALITY=80

# LLM preflight for menu photo orientation + content bbox detection
# IMAGE_PREFLIGHT_ENABLED=true
# IMAGE_PREFLIGHT_MODEL=gemini-2.5-flash-lite
# IMAGE_PREFLIGHT_MAX_DIM=768
# IMAGE_PREFLIGHT_TIMEOUT=15

CACHE_STORE=database
# CACHE_PREFIX=

# Static full-page caching of public menus (silber/page-cache). Enable only
# where nginx serves public/page-cache via try_files (staging/production).
PAGE_CACHE_ENABLED=false

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis

# Mail via Resend (resend/resend-laravel). The From domain must be verified in
# the Resend dashboard (DKIM + SPF + MX records). Use MAIL_MAILER=log locally to
# write emails to storage/logs instead of sending.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@qreaty.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# --- Google OAuth (Socialite) ---
# Create credentials in Google Cloud Console; the authorized redirect URI must
# match GOOGLE_REDIRECT_URI (a backend route in the web group).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- Zalo OAuth (Socialite community provider: socialiteproviders/zalo) ---
ZALO_CLIENT_ID=
ZALO_CLIENT_SECRET=
ZALO_REDIRECT_URI="${APP_URL}/auth/zalo/callback"
# Zalo's profile API is geo-restricted to Vietnamese IPs — set a VN HTTP proxy
# (http://user:pass@vn-host:port) if the server is hosted outside Vietnam.
ZALO_HTTP_PROXY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Per-provider HTTP timeout (wall-clock seconds). Default 5 min — allows cascade to try all 3 providers within job budget.
# LLM_HTTP_TIMEOUT=300
# LLM_JOB_TIMEOUT=1000  # must be > LLM_HTTP_TIMEOUT * max_providers
# QWEN_API_KEY=

# Comma-separated emails allowed to access the Filament admin panel (/panel),
# /horizon, and /pulse when APP_ENV != local. Empty list locks non-local users out.
# ADMIN_EMAILS=admin@example.com,ops@example.com

VITE_APP_NAME="${APP_NAME}"